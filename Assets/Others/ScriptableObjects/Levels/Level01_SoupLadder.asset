  tutorialSteps:
  - stepID: step_1_enter
    instructionText: That ugly tower across the lane is the enemy. Kindly remove
      it. Deploy a Spoon Guard to start!
    highlightTarget: 
    triggerType: OnStart
    triggerCount: 1
    allowContinue: 0
  - stepID: step_2_deploy
    instructionText: Units fight on their own. Your job is to decide what arrives
      and when. Watch the Mud Grunters come!
    highlightTarget: 
    triggerType: OnUnitDeployed
    triggerCount: 1
    allowContinue: 0
  - stepID: step_3_economy
    instructionText: Build a Snack Shack. Armies run on snacks, bad opinions, and
      overtime.
    highlightTarget: 
    triggerType: OnStructureBuilt
    triggerCount: 1
    allowContinue: 0
  - stepID: step_4_defend
    instructionText: That Fork Flinger in the back is annoying on purpose. Send another
      troop!
    highlightTarget: 
    triggerType: OnUnitDeployed
    triggerCount: 3
    allowContinue: 0
  - stepID: step_5_finish
    instructionText: Excellent. Continue diplomacy. Keep pushing until their tower
      falls!
    highlightTarget: 
    triggerType: OnTowerLowHP
    triggerCount: 1
    allowContinue: 1
